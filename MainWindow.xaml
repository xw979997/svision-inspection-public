<Window x:Class="SVisionInspection.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SVISION 智能检测机" Height="820" Width="1380"
        WindowStartupLocation="CenterScreen" Background="#FF0F1216"
        FontFamily="Microsoft YaHei UI" Foreground="#FFE6E6E6">
    <Window.Resources>
        <Style x:Key="CamTag" TargetType="Border">
            <Setter Property="Background" Value="#FF5BB318"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,8,8,0"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#FF161B22"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#FF161B22"/>
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FF12161B">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="26" Height="26" Stroke="#FF8A93A0" StrokeThickness="2"/>
                    <TextBlock Text="SVISION  智能检测机" FontSize="18" FontWeight="Bold" Margin="12,0,24,0" VerticalAlignment="Center"/>
                    <TextBlock Text="用户名：" Foreground="#FF9AA0A6" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtUser" Text="111" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="用户权限：" Foreground="#FF9AA0A6" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtRole" Text="系统管理员" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="数据审计" Foreground="#FFD6DBE0" Background="Transparent" BorderThickness="0" Margin="6,0" Click="Menu_Click"/>
                    <Button Content="用户管理" Foreground="#FFD6DBE0" Background="Transparent" BorderThickness="0" Margin="6,0" Click="Menu_Click"/>
                    <Button Content="退出登录" Foreground="#FFD6DBE0" Background="Transparent" BorderThickness="0" Margin="6,0" Click="Exit_Click"/>
                    <Button Content="退出系统" Foreground="#FFD6DBE0" Background="Transparent" BorderThickness="0" Margin="6,0" Click="Exit_Click"/>
                    <TextBlock Text="精准 | 高效 | 信得过！" Foreground="#FF5BB318" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <UniformGrid Grid.Row="1" Rows="2" Columns="3" Margin="6">
            <Border Background="Black" Margin="4" CornerRadius="4"><Grid><Image x:Name="camImg1" Stretch="UniformToFill"/><Border Style="{StaticResource CamTag}"><TextBlock Text="cam1" Foreground="White" FontSize="12"/></Border></Grid></Border>
            <Border Background="Black" Margin="4" CornerRadius="4"><Grid><Image x:Name="camImg2" Stretch="UniformToFill"/><Border Style="{StaticResource CamTag}"><TextBlock Text="cam2" Foreground="White" FontSize="12"/></Border></Grid></Border>
            <Border Background="Black" Margin="4" CornerRadius="4"><Grid><Image x:Name="camImg3" Stretch="UniformToFill"/><Border Style="{StaticResource CamTag}"><TextBlock Text="cam3" Foreground="White" FontSize="12"/></Border></Grid></Border>
            <Border Background="Black" Margin="4" CornerRadius="4"><Grid><Image x:Name="camImg4" Stretch="UniformToFill"/><Border Style="{StaticResource CamTag}"><TextBlock Text="cam4" Foreground="White" FontSize="12"/></Border></Grid></Border>
            <Border Background="Black" Margin="4" CornerRadius="4"><Grid><Image x:Name="camImg5" Stretch="UniformToFill"/><Border Style="{StaticResource CamTag}"><TextBlock Text="cam5" Foreground="White" FontSize="12"/></Border></Grid></Border>
            <Border Background="Black" Margin="4" CornerRadius="4"><Grid><Image x:Name="camImg6" Stretch="UniformToFill"/><Border Style="{StaticResource CamTag}"><TextBlock Text="cam6" Foreground="White" FontSize="12"/></Border></Grid></Border>
        </UniformGrid>
        <Grid Grid.Row="2" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="数据统计区" Foreground="#FF5BB318" FontWeight="Bold" Margin="6,2"/>
                <Grid Grid.Row="0" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource StatCard}"><StackPanel><TextBlock Text="生产数量" Foreground="#FF9AA0A6"/><TextBlock x:Name="prodCount" Text="0" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/></StackPanel></Border>
                    <Border Grid.Column="1" Style="{StaticResource StatCard}"><StackPanel><TextBlock Text="通过数量" Foreground="#FF9AA0A6"/><TextBlock x:Name="passCount" Text="0" FontSize="30" FontWeight="Bold" Foreground="#FF52C41A" HorizontalAlignment="Center" Margin="0,8,0,0"/></StackPanel></Border>
                    <Border Grid.Column="2" Style="{StaticResource StatCard}"><StackPanel><TextBlock Text="错误数量" Foreground="#FF9AA0A6"/><TextBlock x:Name="errCount" Text="0" FontSize="30" FontWeight="Bold" Foreground="#FFFF4D4F" HorizontalAlignment="Center" Margin="0,8,0,0"/></StackPanel></Border>
                    <StackPanel Grid.Column="3" Margin="20,0,10,0">
                        <Button Content="模拟一次" Click="BtnSimulate_Click" HorizontalAlignment="Center" Background="#FF2D6CDF" Foreground="White" BorderThickness="0" Padding="14,4" Margin="0,0,0,8" Cursor="Hand"/>
                        <Grid Width="120" Height="120">
                            <Ellipse Width="120" Height="120">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF3FBF6B" Offset="0"/>
                                        <GradientStop Color="#FF1E9E55" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="rateText" Text="0.000" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="合格率" Foreground="White" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="1" Background="#FF0B0E12" CornerRadius="4" Margin="6,10,6,0">
                    <TextBox x:Name="logBox" Background="Transparent" Foreground="#FFB7BEC6" BorderThickness="0" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Padding="8" FontSize="12" TextWrapping="Wrap"/>
                </Border>
            </Grid>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="操作区" Foreground="#FF5BB318" FontWeight="Bold" Margin="6,2,0,8"/>
                <ComboBox x:Name="cmbSpec" Height="40" FontSize="18" SelectedIndex="2" Margin="6,0">
                    <ComboBoxItem Content="5ml"/>
                    <ComboBoxItem Content="10ml"/>
                    <ComboBoxItem Content="30ml"/>
                    <ComboBoxItem Content="50ml"/>
                    <ComboBoxItem Content="100ml"/>
                </ComboBox>
                <WrapPanel Margin="6,10,0,0">
                    <CheckBox x:Name="chkCloseDelete" Content="关闭删除" Foreground="#FFD6DBE0" Margin="0,0,16,0"/>
                    <CheckBox x:Name="chkCloseErrSave" Content="关闭错误存图" Foreground="#FFD6DBE0" Margin="0,0,16,0"/>
                    <CheckBox x:Name="chkSaveOk" Content="存储OK图像" Foreground="#FFD6DBE0" IsChecked="True"/>
                </WrapPanel>
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ActionBtn}" Click="BtnLoad_Click" Height="90" Content="加 载"/>
                    <Button Grid.Column="1" Style="{StaticResource ActionBtn}" Click="BtnStart_Click" Height="90" Content="启 动"/>
                    <Button Grid.Column="2" Style="{StaticResource ActionBtn}" Click="BtnReset_Click" Height="90" Background="#FF1E5F66" Content="复 位"/>
                    <Button Grid.Column="3" Style="{StaticResource ActionBtn}" Click="BtnMinimize_Click" Height="90" Content="最小化"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
